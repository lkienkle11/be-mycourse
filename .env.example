# Chung: copy thành `.env` (mọi môi trường đều merge file này trước).
# Tiếp theo copy `.env.<STAGE>.example` → `.env.local` / `.env.staging` / … tùy STAGE.

SERVER_RUN_MODE=debug
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

DATABASE_URL=
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSLMODE=prefer

JWT_SECRET=change-me
API_KEY=
APP_BASE_URL=
APP_CLIENT_BASE_URL=

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

SUPABASE_PROJECT_REF=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# Media integrations (B2 + Gcore + Bunny Stream)
MEDIA_APP_PROVIDER=B2
MEDIA_B2_KEY_ID=
MEDIA_B2_APP_KEY=
# B2 bucket name — dùng dựng URL CDN: <gcore_cdn>/<bucket>/<file>.
# Required for blazer client at startup when KEY_ID + APP_KEY are set; YAML media.b2_bucket overrides if set.
MEDIA_B2_BUCKET=
MEDIA_B2_BASE_URL=

MEDIA_GCORE_API_BASE_URL=https://api.gcore.com
MEDIA_GCORE_API_TOKEN=
MEDIA_GCORE_CDN_URL=

MEDIA_BUNNY_STREAM_API_BASE_URL=https://video.bunnycdn.com
MEDIA_BUNNY_STREAM_API_KEY=
MEDIA_BUNNY_STREAM_READ_ONLY_API_KEY=
MEDIA_BUNNY_LIBRARY_ID=
MEDIA_BUNNY_STREAM_BASE_URL=https://iframe.mediadelivery.net/play
# Bunny Stream CDN pull-zone hostname used to build the video thumbnail URL.
# Bunny's API returns only `thumbnailFileName` — the full URL is composed as
# https://<MEDIA_BUNNY_STREAM_CDN_HOSTNAME>/<videoGuid>/<thumbnailFileName>.
# Leave empty to skip writing a `thumbnail_url` (the iframe embed still works).
MEDIA_BUNNY_STREAM_CDN_HOSTNAME=

MEDIA_BUNNY_STORAGE_ENDPOINT=storage.bunnycdn.com
MEDIA_BUNNY_STORAGE_PASSWORD=

LOCAL_FILE_URL_SECRET=change-this-secret

# When true: after [database] init the binary runs the privileged system-user registration CLI and exits (no HTTP server).
# Populate system_app_config (app_cli_system_password, app_system_env, app_token_env) in Postgres before using this.
CLI_REGISTER_NEW_SYSTEM_USER=false

# Structured logging (Zap) — see config/app.yaml `logging:` and docs/patterns.md
# LOG_LEVEL=info
# LOG_FORMAT=console
# LOG_FILE_PATH=/var/log/mycourse/app.ndjson
# LOG_SERVICE_NAME=be-mycourse
# LOG_ENVIRONMENT=local
# APP_VERSION=dev
# LOG_REDIRECT_STDLOG=false