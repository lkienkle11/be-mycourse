DB_NAME=
DB_SSLMODE=prefer

JWT_SECRET=change-me
API_KEY=

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
AUTO_SYNC_PERMISSION_JOB=false
AUTO_SYNC_ROLE_PERMISSION_JOB=false

SUPABASE_PROJECT_REF=
