# Copy → `.env.local` khi chạy với STAGE=local (config/app-local.yaml).

SERVER_RUN_MODE=debug
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# DB_HOST=127.0.0.1
# DB_NAME=mycourse_dev

# Media integrations (B2 + Gcore + Bunny Stream)
# MEDIA_APP_PROVIDER=B2
# MEDIA_BUNNY_STREAM_API_BASE_URL=https://video.bunnycdn.com
# MEDIA_BUNNY_STREAM_API_KEY=
APP_BASE_URL=
APP_CLIENT_BASE_URL=
MEDIA_BUNNY_STREAM_READ_ONLY_API_KEY=
# MEDIA_BUNNY_LIBRARY_ID=
# MEDIA_BUNNY_STREAM_BASE_URL=https://iframe.mediadelivery.net/play
# MEDIA_BUNNY_STREAM_CDN_HOSTNAME=vz-XXXXXXXX-XXXX.b-cdn.net
# MEDIA_BUNNY_STORAGE_ENDPOINT=storage.bunnycdn.com
# MEDIA_BUNNY_STORAGE_PASSWORD=
# LOCAL_FILE_URL_SECRET=change-this-secret

# OAuth social sign-in (Google + X + Discord). Fill to enable; empty disables the provider.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# X_CLIENT_ID=
# X_CLIENT_SECRET=
# Must match FE NEXT_PUBLIC_X_CALLBACK_URL exactly (localhost callback runs on the FE port).
# X_CALLBACK_URL=http://localhost:3000/auth/x/callback
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# Must match FE NEXT_PUBLIC_DISCORD_CALLBACK_URL exactly (localhost callback runs on the FE port).
# DISCORD_CALLBACK_URL=http://localhost:3000/auth/discord/callback
