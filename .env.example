# Chung: copy thành `.env` (mọi môi trường đều merge file này trước).
# Tiếp theo copy `.env.<STAGE>.example` → `.env.local` / `.env.staging` / … tùy STAGE.

SERVER_RUN_MODE=debug
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

DATABASE_URL=
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSLMODE=prefer
# PostgreSQL schema for app tables (search_path + golang-migrate). Omit or leave empty for public.
SCHEMA_NAME_APP=

JWT_SECRET=change-me
API_KEY=
APP_BASE_URL=
APP_CLIENT_BASE_URL=

# Parent domain for auth cookies (must match FE AUTH_COOKIE_DOMAIN). Unset on localhost.
# AUTH_COOKIE_DOMAIN=yourdomain.net

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# CloudAMQP LavinMQ (RabbitMQ-compatible). Copy AMQP URL from CloudAMQP console → instance details.
# https://www.cloudamqp.com/docs/lavinmq-server.html
CLOUDAMQP_URL=
# Topic exchange (default amq.topic — built-in on LavinMQ / RabbitMQ).
LAVINMQ_EXCHANGE=amq.topic
# Set true when CLOUDAMQP_URL is configured; false skips dial + consumers (local dev without MQ).
LAVINMQ_ENABLED=false

SUPABASE_PROJECT_REF=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# Media integrations (Cloudflare R2 + Bunny Stream)
MEDIA_APP_PROVIDER=R2

# Cloudflare R2 — non-video file upload (S3-compatible API)
MEDIA_R2_ACCOUNT_ID=
MEDIA_R2_ACCESS_KEY_ID=
MEDIA_R2_SECRET_ACCESS_KEY=
MEDIA_R2_BUCKET=mycourse-storage
MEDIA_R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
MEDIA_R2_REGION=auto
# Custom domain connected to R2 bucket (public file URLs: <public_url>/<object_key>)
MEDIA_R2_PUBLIC_URL=https://cdn.yourdomain.com

MEDIA_BUNNY_STREAM_API_BASE_URL=https://video.bunnycdn.com
MEDIA_BUNNY_STREAM_API_KEY=
MEDIA_BUNNY_STREAM_READ_ONLY_API_KEY=
MEDIA_BUNNY_LIBRARY_ID=
MEDIA_BUNNY_STREAM_BASE_URL=https://iframe.mediadelivery.net/play
# Bunny Stream CDN pull-zone hostname (no scheme). Required for thumbnail / HLS / preview URLs.
# Bunny returns only `thumbnailFileName`; full URL = https://<hostname>/<videoGuid>/<thumbnailFileName>
# Example: vz-XXXXXXXX-XXXX.b-cdn.net
MEDIA_BUNNY_STREAM_CDN_HOSTNAME=

MEDIA_BUNNY_STORAGE_ENDPOINT=storage.bunnycdn.com
MEDIA_BUNNY_STORAGE_PASSWORD=

LOCAL_FILE_URL_SECRET=change-this-secret

# When true: after [database] init the binary runs the privileged system-user registration CLI and exits (no HTTP server).
# Populate system_app_config with bcrypt-14 hashes (cost 14) for app_cli_system_password, app_system_env, app_token_env before using this.
# Example: python3 -c "import bcrypt; print(bcrypt.hashpw(b'your-secret', bcrypt.gensalt(rounds=14)).decode())"
CLI_REGISTER_NEW_SYSTEM_USER=false

# When true: after [database] init the binary runs the system login CLI and exits (no HTTP server).
# Prints only the JWT access token to stdout (one line). Example: SYSTEM_TOKEN=$(CLI_SYSTEM_LOGIN=1 go run .)
CLI_SYSTEM_LOGIN=false

# Structured logging (Zap) — see config/app.yaml `logging:` and docs/patterns.md
# LOG_LEVEL=info
# LOG_FORMAT=console
# LOG_FILE_PATH=/var/log/mycourse/app.ndjson
# LOG_DIR=
# LOG_APP_NAME=be-mycourse
# LOG_VENDOR=mycourse
# LOG_PATH_MODE=user
# LOG_FILE_ENABLED=false
# LOG_CONSOLE=true
# LOG_MAX_SIZE_MB=100
# LOG_MAX_BACKUPS=10
# LOG_MAX_AGE_DAYS=14
# LOG_COMPRESS=true
# LOG_INSTANCE_ID=
# LOG_SERVICE_NAME=be-mycourse
# LOG_ENVIRONMENT=local
# APP_VERSION=dev
# LOG_REDIRECT_STDLOG=false

# Example resolved directories when LOG_FILE_ENABLED=true and LOG_DIR is empty:
# - macOS user mode: ~/Library/Logs/mycourse/be-mycourse
# - Linux user mode: ${XDG_STATE_HOME:-~/.local/state}/be-mycourse/logs
# - Windows user mode: %LOCALAPPDATA%\mycourse\be-mycourse\logs